BEGIN {
    str path = "tests/data_500m.csv"
    num chunk_size = 10000000

    num fh = core.os.open(path)
    if (fh < 0) { print "ERROR: could not open file"; exit(1) }

    # read header line
    arr header_lines = core.os.chunk(fh, 1)
    arr headers = core.generics.split(header_lines[0], ",")
    num ncols = core.generics.length(headers)
    print "Columns : " .. ncols .. "  →  " .. core.generics.join(headers, ", ")

    fn mark_row = fn(row) {
        row["_processed"] = "1"
        return row
    }

    arr partial_indexes = []
    num global_offset = 0

    arr raw_lines = core.os.chunk(fh, chunk_size)
    while (core.generics.length(raw_lines) > 0) {
        num chunk_len = core.generics.length(raw_lines)

        # parse lines → rows
        arr chunk_rows = []
        num li = 0
        while (li < chunk_len) {
            arr fields = core.generics.split(raw_lines[li], ",")
            map row = {}
            num j = 0
            while (j < ncols) {
                row[headers[j]] = fields[j]
                j = j + 1
            }
            push(chunk_rows, row)
            li = li + 1
        }

        map chunk_idx = core.process.assign(chunk_rows, mark_row, global_offset)
        push(partial_indexes, chunk_idx)
        global_offset = global_offset + chunk_len

        print "Processed : " .. global_offset .. " rows"

        raw_lines = core.os.chunk(fh, chunk_size)
    }

    core.os.close(fh)

    print "Merging " .. core.generics.length(partial_indexes) .. " partial indexes..."
    map full_idx = core.ds.flatten(partial_indexes)
    print "Done. Columns indexed : " .. core.generics.length(full_idx)
    print "Sample (name col) : " .. core.str.substr(core.format.json(full_idx["name"]), 0, 200)
}