CHECK("join/empty_sep",  core.generics.join(["x","y","z"], ""), "xyz")


# ── §21  Regex ──────────────────────────────────────────────────────────────
CHECK_BOOL("regex/match_t",  "hello123" ~  /[0-9]+/, TRUE)
CHECK_BOOL("regex/match_f",  "helloabc" ~  /[0-9]+/, FALSE)
CHECK_BOOL("regex/nmatch_t", "helloabc" !~ /[0-9]+/, TRUE)
map rm = core.regex.match("foo123bar", /([0-9]+)/)
CHECK("regex/match_val",   rm["match"],  "123")
CHECK_NUM("regex/test_t",  core.regex.test("abc123", /\d+/), 1)
CHECK_NUM("regex/test_f",  core.regex.test("abcdef", /\d+/), 0)
CHECK("regex/replace",     core.regex.replace("aabbcc", /b+/, "X"),           "aaXcc")
CHECK("regex/replace_all", core.regex.replace_all("a1b2c3", /[0-9]/, "N"),    "aNbNcN")
arr rs = core.regex.split("one1two2three", /[0-9]/)
print rs
print rs[0]
print rs[1]
print rs[2]
print rs.len
rs[x]>print x
CHECK_NUM("regex/split_n", rs.len, 3)
CHECK("regex/split_0",     rs[0],  "one")
CHECK_BOOL("regex/icase_t", "Hello" ~ /hello/i, TRUE)
CHECK_BOOL("regex/icase_f", "Hello" ~ /hello/,  FALSE)
CHECK("regex/icase_repl",  core.regex.replace_all("aAbBcC", /[a-z]/i, "X"), "XXXXXX")


# ── §22  Pipe (|>) ──────────────────────────────────────────────────────────
num fn pipe_double(num n) { return n * 2 }
num fn pipe_inc(num n)    { return n + 1 }
CHECK_NUM("pipe/basic",  5 |> pipe_double,         10)
CHECK_NUM("pipe/inc",    9 |> pipe_inc,             10)
CHECK("pipe/str",        "hello" |> core.str.upper,        "HELLO")
# chain: pipe the result via a temp variable
num pipe_mid = 5 |> pipe_double
CHECK_NUM("pipe/chain",  pipe_mid |> pipe_inc,      11)




# ── §24  State & type introspection ─────────────────────────────────────────
num stv = 42
CHECK("state/ok",    stv.state, "OK")
num nav_s = NAV
CHECK("state/nav",   nav_s.state, "NAV")
CHECK("type/num",    stv.type,  "num")
CHECK("type/str",    "hi".type, "str")
CHECK("type/arr",    [].type,   "arr")
CHECK("type/map",    {}.type,   "map")


# ── §25  NAV propagation ────────────────────────────────────────────────────
num nprop = NAV + 5
CHECK("nav/propagates", nprop.state, "NAV")
num ncoal = NAV ?? 7
CHECK_NUM("nav/coalesce", ncoal, 7)


# ── §26  NULL ───────────────────────────────────────────────────────────────
num nl = NULL
CHECK("null/state",   nl.state,     "NULL")
CHECK_BOOL("null/eq", NULL == NULL, TRUE)
CHECK_BOOL("null/neq",NULL == NAV,  FALSE)


# ── §27  void as expression (regression) ───────────────────────────────────
num vd = void
CHECK("void/state", vd.state, "VOID")


# ── §28  format module ──────────────────────────────────────────────────────
CHECK("fmt/fixed",     core.format.fixed(3.14159, 2),   "3.14")
CHECK("fmt/comma",     core.format.comma(1234567),       "1,234,567")
CHECK("fmt/hex",       core.format.hex(255),             "ff")
CHECK("fmt/bin",       core.format.bin(10),              "1010")
CHECK("fmt/percent",   core.format.percent(0.755, 1),    "75.5%")
CHECK("fmt/pad_left",  core.format.pad_left("hi", 5),   "   hi")
CHECK("fmt/pad_right", core.format.pad_right("hi", 5),  "hi   ")
CHECK("fmt/sci",       core.format.sci(12345.0, 2),      "1.23e+04")
str jout = core.format.json({"k": "v"})
CHECK_BOOL("fmt/json_k", core.generics.contains(jout, "\"k\""), TRUE)
map jparsed = core.format.from_json('{"a":1,"b":"two"}')
CHECK_NUM("fmt/from_json_num", jparsed["a"], 1)
CHECK("fmt/from_json_str",     jparsed["b"], "two")

# ── §29  Higher-order functions ─────────────────────────────────────────────
num fn apply_twice(fn f, num v) { return f(f(v)) }
CHECK_NUM("hof/apply_twice_add1", apply_twice(fn(num n) { return n + 1 }, 5), 7)
CHECK_NUM("hof/apply_twice_dbl",  apply_twice(fn(num n) { return n * 2 }, 3), 12)
# ── §30  Recursive data structures ─────────────────────────────────────────
map tree = {
    "val":   1,
    "left":  {"val": 2, "left": NULL, "right": NULL},
    "right": {"val": 3, "left": NULL, "right": NULL}
}
CHECK_NUM("tree/root",  tree["val"],          1)
CHECK_NUM("tree/left",  tree["left"]["val"],  2)
CHECK_NUM("tree/right", tree["right"]["val"], 3)


# ── §31  core.generics ─────────────────────────────────────────────────────
CHECK_NUM("gen/length_arr",   core.generics.size([1,2,3,4,5]),     5)
CHECK_NUM("gen/length_str",   core.generics.size("hello"),         5)
CHECK_BOOL("gen/cont_arr_t",  core.generics.contains([1,2,3], 2),   TRUE)
CHECK_BOOL("gen/cont_arr_f",  core.generics.contains([1,2,3], 9),   FALSE)
CHECK_BOOL("gen/cont_str_t",  core.generics.contains("foobar","foo"),TRUE)
arr stripped = core.generics.strip([1, NAV, 2, NULL, 3])
CHECK_NUM("gen/strip", stripped.len, 3)


# ── §32  ds module ──────────────────────────────────────────────────────────
arr ds = [
    {"name": "alice", "score": 90, "dept": "eng"},
    {"name": "bob",   "score": 70, "dept": "eng"},
    {"name": "carol", "score": 85, "dept": "hr"},
    {"name": "dave",  "score": 95, "dept": "hr"},
    {"name": "eve",   "score": 60, "dept": "eng"}
]
map r0 = core.ds.row(ds, 0)
CHECK("ds/row0_name",    r0["name"],  "alice")
CHECK_NUM("ds/row0_score", r0["score"], 90)
arr scores = core.ds.column(ds, "score")
CHECK_NUM("ds/column_len", scores.len, 5)
arr sasc  = core.ds.sort(ds, "score")
CHECK("ds/sort_asc",  core.ds.row(sasc,  0)["name"], "eve")
arr sdesc = core.ds.sort(ds, "score", "desc")
CHECK("ds/sort_desc", core.ds.row(sdesc, 0)["name"], "dave")
arr eng = core.ds.filter(ds, fn(map row) { return row["dept"] == "eng" })
CHECK_NUM("ds/filter", eng.len, 3)
map agg = core.ds.agg(ds, "dept", "score")
CHECK_BOOL("ds/agg_eng", has(agg, "eng"), TRUE)
CHECK_BOOL("ds/agg_hr",  has(agg, "hr"),  TRUE)


# ── §33  process.assign (regression: was inverted-index) ───────────────────
arr stamped = core.process.assign(ds, fn(map row) {
    row["_tag"] = "tested"
    return row
})
CHECK_NUM("assign/len",  stamped.len, 5)
map st0 = core.ds.row(stamped, 0)
CHECK("assign/tag",  st0["_tag"],  "tested")
CHECK("assign/name", st0["name"],  "alice")


# ── §34  ds.flatten (regression: was null after wrong assign shape) ─────────
arr flat = core.ds.flatten(stamped)
CHECK_NUM("flatten/len",  flat.len, 5)
map fl0 = core.ds.row(flat, 0)
CHECK("flatten/name", fl0["name"], "alice")
CHECK("flatten/tag",  fl0["_tag"], "tested")


# ── §35  process.run with XF fn (regression: was returning NAV) ─────────────
arr chunks = core.process.split(ds, 3)
CHECK_NUM("process/chunks", chunks.len, 3)

arr fn tag_chunk(arr chunk) {
    return core.process.assign(chunk, fn(map row) {
        row["_parallel"] = TRUE
        return row
    })
}
arr workers = []
chunks[chunk] > { push(workers, core.process.worker(tag_chunk, chunk)) }
print core.process.run(workers)
arr results = core.process.run(workers)
arr combined = core.ds.flatten(results)
print combined
CHECK_NUM("process/run_len", combined.len, 5)
map cr0 = core.ds.row(combined, 0)
CHECK_BOOL("process/run_tag", cr0["_parallel"], TRUE)


# ── §36  Nested map mutation ────────────────────────────────────────────────
map nmut = {"a": {"b": {"c": 42}}}
nmut["a"]["b"]["c"] = 99
CHECK_NUM("nested_mut/deep",    nmut["a"]["b"]["c"], 99)
nmut["a"]["b"]["d"] = 100
CHECK_NUM("nested_mut/new_key", nmut["a"]["b"]["d"], 100)


# ── §37  delete ─────────────────────────────────────────────────────────────
arr del_a = [1,2,3,4,5]
delete del_a[2]
CHECK_NUM("delete/arr_len", del_a.len, 4)
CHECK_NUM("delete/arr_val", del_a[2],  4)
map del_m = {"a":1,"b":2,"c":3}
delete del_m["b"]
CHECK_NUM("delete/map_len",   del_m.len,     2)
CHECK_BOOL("delete/map_gone", has(del_m,"b"),FALSE)


# ── §38  Chained member access ──────────────────────────────────────────────
arr chain = [1,2,3,4,5]
CHECK_NUM("chain/len",   chain.len,   5)
CHECK("chain/type",      chain.type,  "arr")
CHECK("chain/state",     chain.state, "OK")
CHECK_NUM("chain/str_len", "xf".len,  2)


# ── §39  Higher-order / anonymous fn ────────────────────────────────────────
arr fn map_arr(arr inp, fn f) {
    arr out = []
    for (v in inp) { push(out, f(v)) }
    return out
}
arr doubled = map_arr([1,2,3,4], fn(num n) { return n * 2 })
CHECK_NUM("anon_fn/0", doubled[0], 2)
CHECK_NUM("anon_fn/3", doubled[3], 8)


# ── §40  Walrus in condition ────────────────────────────────────────────────
num walrus_check = 0
num wc = 0
if ((wc := 42) > 10) { walrus_check = wc }
CHECK_NUM("walrus/cond", walrus_check, 42)


# ── §41  JSON roundtrip ─────────────────────────────────────────────────────
map orig = {"flag": TRUE, "nested": {"x": 99}}
str js = core.format.json(orig)
CHECK_BOOL("json/has_nested", core.generics.contains(js, "\"nested\""), TRUE)
map parsed = core.format.from_json(js)
CHECK_NUM("json/nested_x", parsed["nested"]["x"], 99)


# ── §42  Stress: 10k loop ───────────────────────────────────────────────────
num big_sum = 0
num bi = 1
while (bi <= 10000) {
    big_sum = big_sum + bi
    bi = bi + 1
}
CHECK_NUM("stress/10k_sum", big_sum, 50005000)


# ── §43  Stress: recursion ──────────────────────────────────────────────────
num fn fact(num n) {
    if (n <= 1) { return 1 }
    return n * fact(n-1)
}
CHECK_NUM("stress/fact_10", fact(10), 3628800)

num fn rdepth(num n) {
    if (n == 0) { return 0 }
    return 1 + rdepth(n-1)
}
CHECK_NUM("stress/depth_20", rdepth(20), 20)


# ── §44  Stress: string build ───────────────────────────────────────────────
str big_s = ""
num si = 0
while (si < 100) { big_s = big_s .. "x"; si = si + 1 }
CHECK_NUM("stress/str_len", big_s.len, 100)


# ── §45  Stress: large map ──────────────────────────────────────────────────
map big_map = {}
num mi = 0
while (mi < 200) { big_map[mi .. ""] = mi * 2; mi = mi + 1 }
CHECK_NUM("stress/map_len",   big_map.len,   200)
CHECK_NUM("stress/map_key0",  big_map["0"],    0)
CHECK_NUM("stress/map_key99", big_map["99"], 198)


# ── §46  Multiple chained assignment ────────────────────────────────────────
num ma1 = 0
num ma2 = 0
num ma3 = 0
ma1 = ma2 = ma3 = 7
CHECK_NUM("multi_assign/1", ma1, 7)
CHECK_NUM("multi_assign/2", ma2, 7)
CHECK_NUM("multi_assign/3", ma3, 7)
# ── Final tally ─────────────────────────────────────────────────────────────
print ""
print "══════════════════════════════════════"
print "  PASS: " .. _pass
print "  FAIL: " .. _fail
print "══════════════════════════════════════"

if (_fail > 0) {
    print "RESULT: FAILED"
    exit(1)
} else {
    print "RESULT: ALL PASSED"
    exit(0)
}
}