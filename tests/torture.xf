# =============================================================================
# xf torture test suite
# Run with:  xf -r torture.xf
# Every test calls PASS(label) or FAIL(label, got, expected).
# Final line prints total counts; exits 1 if any failure.
# =============================================================================
num _pass = 0
num _fail = 0

void fn PASS(str label) {
    print "PASS  " .. label
    _pass = _pass + 1
}
void fn FAIL(str label, str got, str expected) {
    print "FAIL  " .. label .. "  got=" .. got .. "  expected=" .. expected
    _fail = _fail + 1
}

void fn CHECK(str label, str got, str expected) {
    if (got == expected) { PASS(label) }
    else { FAIL(label, got, expected) }
}

void fn CHECK_NUM(str label, num got, num expected) {
    if (got == expected) { PASS(label) }
    else { FAIL(label, got .. "", expected .. "") }
}

void fn CHECK_BOOL(str label, bool got, bool expected) {
    if (got == expected) { PASS(label) }
    else { FAIL(label, got .. "", expected .. "") }
}
BEGIN{


# ── §1  Literals & basic types ─────────────────────────────────────────────
CHECK_NUM("lit/int",     42,    42)
CHECK_NUM("lit/float",   3.14,  3.14)
CHECK("lit/str/dq",      "hello", "hello")
CHECK("lit/str/sq",      'world', 'world')
CHECK("lit/str/esc",     "a\tb",  "a\tb")
CHECK_BOOL("lit/TRUE",   TRUE,    TRUE)
CHECK_BOOL("lit/FALSE",  FALSE,   FALSE)
CHECK_NUM("lit/hex",     0xFF,    255)


# ── §2  Arithmetic ──────────────────────────────────────────────────────────
CHECK_NUM("arith/add",    2 + 3,       5)
CHECK_NUM("arith/sub",    10 - 4,      6)
CHECK_NUM("arith/mul",    3 * 4,       12)
CHECK_NUM("arith/div",    9 / 4,       2.25)
CHECK_NUM("arith/mod",    10 % 3,      1)
CHECK_NUM("arith/pow",    2 ^ 10,      1024)
CHECK_NUM("arith/neg",    -7,          -7)
CHECK_NUM("arith/prec",   2 + 3 * 4,   14)
CHECK_NUM("arith/parens", (2 + 3) * 4, 20)
CHECK_NUM("arith/unary",  -(3+2),      -5)


# ── §3  String concat (..) ─────────────────────────────────────────────────
CHECK("concat/basic",     "foo" .. "bar",    "foobar")
CHECK("concat/num",       "val=" .. 42,      "val=42")
CHECK("concat/chain",     "a" .. "b" .. "c", "abc")
CHECK("concat/empty",     "" .. "x",         "x")


# ── §4  Comparison ──────────────────────────────────────────────────────────
CHECK_BOOL("cmp/eq_num",   3 == 3,   TRUE)
CHECK_BOOL("cmp/eq_str",   "a"=="a", TRUE)
CHECK_BOOL("cmp/neq",      1 != 2,   TRUE)
CHECK_BOOL("cmp/lt",       1 < 2,    TRUE)
CHECK_BOOL("cmp/gt",       2 > 1,    TRUE)
CHECK_BOOL("cmp/lte_eq",   2 <= 2,   TRUE)
CHECK_BOOL("cmp/gte_eq",   2 >= 2,   TRUE)
CHECK_NUM("cmp/ship_lt",   1 <=> 2,  -1)
CHECK_NUM("cmp/ship_eq",   2 <=> 2,   0)
CHECK_NUM("cmp/ship_gt",   3 <=> 2,   1)
CHECK_BOOL("cmp/arr_true", ([] == TRUE), FALSE)
CHECK_BOOL("cmp/arr_false", [] == FALSE, FALSE)
CHECK_NUM("cmp/ship_cross", [] <=> TRUE, 0)


# ── §5  Logical ─────────────────────────────────────────────────────────────
CHECK_BOOL("logic/and_tt",  TRUE  && TRUE,  TRUE)
CHECK_BOOL("logic/and_tf",  TRUE  && FALSE, FALSE)
CHECK_BOOL("logic/or_ff",   FALSE || FALSE, FALSE)
CHECK_BOOL("logic/or_tf",   FALSE || TRUE,  TRUE)
CHECK_BOOL("logic/not_t",   !TRUE,          FALSE)
CHECK_BOOL("logic/not_f",   !FALSE,         TRUE)
CHECK_BOOL("logic/short_and", FALSE && (1/0 > 0), FALSE)
CHECK_BOOL("logic/short_or",  TRUE  || (1/0 > 0), TRUE)


# ── §6  Coalesce (??) ───────────────────────────────────────────────────────
num nav_val = NAV
CHECK_NUM("coalesce/nav", nav_val ?? 99, 99)
CHECK_NUM("coalesce/ok",  42      ?? 99, 42)


# ── §7  Variables & assignment ──────────────────────────────────────────────
num x = 10
x = x + 5
CHECK_NUM("var/assign",    x, 15)
x += 3
CHECK_NUM("var/plus_eq",   x, 18)
x -= 8
CHECK_NUM("var/minus_eq",  x, 10)
x *= 3
CHECK_NUM("var/star_eq",   x, 30)
x /= 6
CHECK_NUM("var/slash_eq",  x,  5)
x %= 3
CHECK_NUM("var/pct_eq",    x,  2)
num y = 0
y++
CHECK_NUM("var/inc", y, 1)
y--
CHECK_NUM("var/dec", y, 0)
str sv = "hello"
CHECK("var/str", sv, "hello")


# ── §8  Walrus (:=) ─────────────────────────────────────────────────────────
# Walrus: bare name := expr, no type annotation on the LHS
num wv = 0
num wtest = (wv := 7) + 1
CHECK_NUM("walrus/val",  wv,    7)
CHECK_NUM("walrus/expr", wtest, 8)


# ── §9  Ternary ─────────────────────────────────────────────────────────────
CHECK_NUM("ternary/true",   TRUE  ? 1 : 2, 1)
CHECK_NUM("ternary/false",  FALSE ? 1 : 2, 2)
CHECK("ternary/nested", TRUE ? (FALSE ? "a" : "b") : "c", "b")


# ── §10  if / elif / else ──────────────────────────────────────────────────
num if_result = 0
if (1 > 2) { if_result = 1 }
elif (2 > 3) { if_result = 2 }
elif (3 > 2) { if_result = 3 }
else { if_result = 4 }
CHECK_NUM("if/elif_else", if_result, 3)

# if body always needs braces
num if2 = 0
if (TRUE) { if2 = 1 }
else      { if2 = 2 }
CHECK_NUM("if/braces", if2, 1)


# ── §11  while ──────────────────────────────────────────────────────────────
num wsum = 0
num wi = 1
while (wi <= 5) {
    wsum = wsum + wi
    wi = wi + 1
}
CHECK_NUM("while/sum", wsum, 15)

num wb = 0
num wbi = 0
while (wbi < 10) {
    wbi = wbi + 1
    if (wbi == 5) { break }
    wb = wb + 1
}
CHECK_NUM("while/break", wb, 4)


# ── §12  for-in ─────────────────────────────────────────────────────────────
arr fa = [10, 20, 30, 40]
num fsum = 0
for (v in fa) { fsum = fsum + v }
CHECK_NUM("for/arr_sum", fsum, 100)

# key-value iteration over a map: iterate keys, subscript for values
map fm = {"a": 1, "b": 2, "c": 3}
num fmap_sum = 0
for (k in fm) { fmap_sum = fmap_sum + fm[k] }
CHECK_NUM("for/map_sum", fmap_sum, 6)

num fnext = 0
for (v in [1,2,3,4,5]) {
    if (v == 3) { next }
    fnext = fnext + v
}
CHECK_NUM("for/next", fnext, 12)


# ── §13  Functions ──────────────────────────────────────────────────────────
num fn add(num a, num b) { return a + b }
CHECK_NUM("fn/basic", add(3, 4), 7)

num fn fib(num n) {
    if (n <= 1) { return n }
    return fib(n-1) + fib(n-2)
}
CHECK_NUM("fn/fib", fib(10), 55)

str fn greet(str name) { return "Hello, " .. name .. "!" }
CHECK("fn/str_return", greet("world"), "Hello, world!")

str fn polarity(num n) {
    if (n > 0) { return "pos" }
    if (n < 0) { return "neg" }
    return "zero"
}
CHECK("fn/multi_return/pos",  polarity(5),  "pos")
CHECK("fn/multi_return/neg",  polarity(-1), "neg")
CHECK("fn/multi_return/zero", polarity(0),  "zero")

# higher-order
num fn apply(fn f, num v) { return f(v) }
CHECK_NUM("fn/higher_order", apply(fn(num n) { return n * n }, 6), 36)

# outer variable capture
num outer = 100
num fn add_outer(num n) { return n + outer }
CHECK_NUM("fn/captures_outer", add_outer(5), 105)


# ── §14  Arrays ─────────────────────────────────────────────────────────────
arr a = [1, 2, 3]
CHECK_NUM("arr/index",      a[0],  1)
CHECK_NUM("arr/index_last", a[2],  3)
CHECK_NUM("arr/len",        a.len, 3)
push(a, 4)
CHECK_NUM("arr/push_len",   a.len,   4)
CHECK_NUM("arr/push_val",   a[3],    4)
num popped = pop(a)
CHECK_NUM("arr/pop_val",    popped,  4)
CHECK_NUM("arr/pop_len",    a.len,   3)
num shifted = shift(a)
CHECK_NUM("arr/shift_val",  shifted, 1)
CHECK_NUM("arr/shift_len",  a.len,   2)
unshift(a, 99)
CHECK_NUM("arr/unshift_val", a[0],   99)
CHECK_NUM("arr/unshift_len", a.len,   3)
arr nested = [[1,2],[3,4]]
CHECK_NUM("arr/nested",     nested[1][0], 3)
arr aempty = []
CHECK_NUM("arr/empty_len",  aempty.len,   0)


# ── §15  Maps ───────────────────────────────────────────────────────────────
map m = {"x": 10, "y": 20}
CHECK_NUM("map/get",       m["x"],  10)
CHECK_NUM("map/get2",      m["y"],  20)
m["z"] = 30
CHECK_NUM("map/set_new",   m["z"],  30)
m["x"] = 99
CHECK_NUM("map/overwrite", m["x"],  99)
CHECK_NUM("map/len",       m.len,    3)
CHECK_BOOL("map/has_t",    has(m,"y"),     TRUE)
CHECK_BOOL("map/has_f",    has(m,"nope"),  FALSE)
remove(m, "z")
CHECK_NUM("map/remove_len",  m.len, 2)
CHECK_BOOL("map/remove_gone",has(m,"2"), FALSE)
map m2 = {"1": "hi", "2": "world"}
CHECK("map/strkey_1", m2["1"], "hi")
CHECK("map/strkey_2", m2["2"], "world")
arr mk = keys(m)
CHECK_NUM("map/keys_len", mk.len, 2)


# ── §16  Sets ───────────────────────────────────────────────────────────────
set st = set{"alpha", "beta", "gamma"}
CHECK_BOOL("set/has_t", has(st, "alpha"), TRUE)
CHECK_BOOL("set/has_f", has(st, "delta"), FALSE)
CHECK_NUM("set/len",    st.len,           3)


# ── §17  Tuples ─────────────────────────────────────────────────────────────
tuple t2 = (42, "hello")
CHECK_NUM("tuple/idx0", t2[0], 42)
CHECK("tuple/idx1",     t2[1], "hello")
CHECK_NUM("tuple/len",  t2.len, 2)


# ── §18  String builtins ────────────────────────────────────────────────────
CHECK("str/upper",      core.str.upper("hello"),          "HELLO")
CHECK("str/lower",      core.str.lower("WORLD"),          "world")
CHECK("str/trim",        core.str.trim("  hi  "),            "hi")
CHECK("str/substr",      core.str.substr("abcdef", 2, 3),    "cde")
CHECK_NUM("str/index",   core.str.index("abcdef", "cd"),     2)
CHECK_NUM("str/len",     len("hello"),              5)
CHECK("str/sprintf",     core.str.sprintf("%05d", 42),       "00042")
CHECK("str/repeat",      core.str.repeat("ab", 3),  "ababab")
CHECK("str/reverse",     core.str.reverse("abc"),    "cba")
CHECK("str/replace",     core.str.replace("aXbXc","X","-"),     "a-bXc")
