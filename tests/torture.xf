CHECK_BOOL("str/ends_t",   core.str.ends_with("foobar","bar"),   TRUE)
CHECK_BOOL("str/ends_f",   core.str.ends_with("foobar","foo"),   FALSE)
CHECK_BOOL("str/cont_t",   core.str.contains("foobar","oob"),    TRUE)
CHECK_BOOL("str/cont_f",   core.str.contains("foobar","xyz"),    FALSE)


# ── §19  Math builtins ──────────────────────────────────────────────────────
CHECK_NUM("math/abs_neg", core.math.abs(-5),              5)
CHECK_NUM("math/abs_pos",  core.math.abs(5),               5)
